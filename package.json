{
	"name": "grandpa-web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev:panda": "panda --watch",
		"dev:vite": "vite dev",
		"dev": "concurrently \"npm run dev:panda\" \"npm run dev:vite\"",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo '' & panda codegen",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@pandacss/dev": "^1.11.4",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"concurrently": "^10.0.3",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	}
}
